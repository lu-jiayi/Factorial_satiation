filter(type == "filler") %>%
mutate(filler_cond = str_sub(unique_id, 2, 3))
block_means_filler = data_filler %>%
group_by(block_number, filler_cond) %>%
summarize(response = mean(response), z_score = mean(z_score)) %>%
ungroup()
